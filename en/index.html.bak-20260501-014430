    <script>
    (function() {
        var PAIR = '4btoeuklvrqycz8r8xugana4czsvopwsmzbfpvghhghr';
        var jsonPath = '/admin/pret.json';

        function fmt(n, dec) { return (n !== null && n !== undefined && !isNaN(n)) ? Number(n).toFixed(dec) : '—'; }
        function fmtPula(n) {
            if (!n || isNaN(n)) return '—';
            if (n >= 1e9) return (n/1e9).toFixed(2) + ' Barns of PULA';
            if (n >= 1e6) return (n/1e6).toFixed(2) + ' Carts of PULA';
            if (n >= 1e3) return (n/1e3).toFixed(2) + ' Bundles of PULA';
            if (n >= 1) {
                var rounded = Math.round(n);
                return rounded.toLocaleString('en-US') + ' PULA';
            }
            if (n >= 1e-3) return (n*1e3).toFixed(2) + ' Drops of PULA';
            return (n*1e6).toFixed(2) + ' Nothing';
        }
        function fmtInt(n) { return Number(n).toLocaleString('en-US'); }

        function buildContent(d) {
            var sep = '<span class="banda-sep">◆</span>';
            var pipe = ' <span class="banda-unit">|</span> ';
            var vals = [
                '<span class="banda-val">' + fmt(d.ron,2) + '</span> <span class="banda-unit">RON</span>',
                '<span class="banda-val">' + fmt(d.usd,4) + '</span> <span class="banda-unit">USD</span>',
                '<span class="banda-val">' + fmt(d.eur,4) + '</span> <span class="banda-unit">EUR</span>',
                '<span class="banda-val">' + fmt(d.sol,5) + '</span> <span class="banda-unit">SOL</span>'
            ];
            var html = '<span class="banda-item"><span class="banda-label">1 CART:</span> ' + vals.join(pipe) + '</span>';
            html += sep + '<span class="banda-item"><span class="banda-label">MARKET CAP:</span> <span class="banda-val">$' + fmtInt(Math.round(d.market_cap_usd)) + '</span></span>';
            if (d.motorina_ron && d.ron) {
                var pula_per_litru = (d.motorina_ron / d.ron) * 1e6;
                html += sep + '<span class="banda-item"><span class="banda-label">1L Diesel:</span> <span class="banda-val">' + fmtPula(pula_per_litru) + '</span></span>';
            }
            if (d.kwh_ron && d.ron) {
                var pula_per_kwh = (d.kwh_ron / d.ron) * 1e6;
                html += sep + '<span class="banda-item"><span class="banda-label">1 kWh:</span> <span class="banda-val">' + fmtPula(pula_per_kwh) + '</span></span>';
            }
            if (d.aur_ron_per_gram && d.ron) {
                var pula_per_gram_aur = (d.aur_ron_per_gram / d.ron) * 1e6;
                html += sep + '<span class="banda-item"><span class="banda-label">1g Gold:</span> <span class="banda-val">' + fmtPula(pula_per_gram_aur) + '</span></span>';
            }
            html += sep + '<span class="banda-item"><span class="banda-label">SUPPLY:</span> <span class="banda-val">' + fmtInt(d.supply) + '</span> <span class="banda-unit">PULA</span></span>';
            return html + sep + html;
        }

        function update(d) {
            var el = document.getElementById('bandaContinut');
            if (el) el.innerHTML = buildContent(d);
            localStorage.setItem('pula_pret', JSON.stringify(d));
        }

        function fetchLive(staticData) {
            var priceUsd = window.pulaPriceUsd || 2.368e-6;
            var carutaUsd = priceUsd * 1e6;
            var ron = window.ratesRon || 4.7;
            var d = Object.assign({}, staticData, {
                usd: carutaUsd,
                ron: carutaUsd * ron,
                eur: carutaUsd * (window.ratesEur || 0.92),
                sol: window.pulaPriceSol || 0,
                market_cap_usd: Math.round(priceUsd * (staticData.supply || 1e9))
            });
            fetch('https://api.metals.live/v1/spot/gold')
                .then(function(r){ return r.json(); })
                .then(function(gold) {
                    var ozUsd = Array.isArray(gold) ? gold[0].gold : gold.gold;
                    if (ozUsd) d.aur_ron_per_gram = (ozUsd / 31.103) * ron;
                    update(d);
                }).catch(function(){ update(d); });
        }

        window._pulaStaticData = {};
        document.addEventListener('pulaReady', function() { fetchLive(window._pulaStaticData); });
        fetch(jsonPath + '?v=' + Date.now())
            .then(function(r){ return r.json(); })
            .then(function(staticData) {
                window._pulaStaticData = staticData;
                update(staticData);
                fetchLive(staticData);
            })
            .catch(function() {
                var ls = localStorage.getItem('pula_pret');
                var fallback = ls ? JSON.parse(ls) : {};
                update(fallback);
                fetchLive(fallback);
            });
    })();
    </script>

